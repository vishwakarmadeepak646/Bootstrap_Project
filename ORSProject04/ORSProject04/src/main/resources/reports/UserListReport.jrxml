<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="UserListReport"
              pageWidth="842" pageHeight="595"
              orientation="Landscape"
              columnWidth="782"
              leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20">

    <field name="id"        class="java.lang.Long"/>
    <field name="firstName" class="java.lang.String"/>
    <field name="lastName"  class="java.lang.String"/>
    <field name="login"     class="java.lang.String"/>
    <field name="dob"       class="java.util.Date"/>
    <field name="mobileNo"  class="java.lang.String"/>
    <field name="gender"    class="java.lang.String"/>
    <field name="roleId"    class="java.lang.Long"/>
    <field name="lock"      class="java.lang.String"/>

    <title>
        <band height="55">
            <rectangle>
                <reportElement x="0" y="0" width="782" height="46" backcolor="#1565C0" forecolor="#1565C0"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="4" width="782" height="38" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[User List Report]]></text>
            </staticText>
        </band>
    </title>

    <pageHeader>
        <band height="18">
            <staticText>
                <reportElement x="0" y="0" width="391" height="18" forecolor="#666666"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <text><![CDATA[Online Result System]]></text>
            </staticText>
            <textField pattern="dd-MM-yyyy HH:mm">
                <reportElement x="391" y="0" width="391" height="18" forecolor="#666666"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
        </band>
    </pageHeader>

    <columnHeader>
        <band height="26">
            <rectangle>
                <reportElement x="0" y="0" width="782" height="26" backcolor="#0D2137" forecolor="#0D2137"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="0" width="25" height="26" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[#]]></text>
            </staticText>
            <staticText>
                <reportElement x="25" y="0" width="40" height="26" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="65" y="0" width="100" height="26" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[First Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="165" y="0" width="100" height="26" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Last Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="265" y="0" width="130" height="26" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Login ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="395" y="0" width="80" height="26" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Date of Birth]]></text>
            </staticText>
            <staticText>
                <reportElement x="475" y="0" width="100" height="26" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Mobile No]]></text>
            </staticText>
            <staticText>
                <reportElement x="575" y="0" width="65" height="26" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Gender]]></text>
            </staticText>
            <staticText>
                <reportElement x="640" y="0" width="60" height="26" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Role ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="700" y="0" width="82" height="26" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Status]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="22">
            <rectangle>
                <reportElement x="0" y="0" width="782" height="22" backcolor="#EEF2F7">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <textField>
                <reportElement x="0" y="0" width="25" height="22" forecolor="#888888"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="25" y="0" width="40" height="22" forecolor="#888888"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="65" y="0" width="100" height="22"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{firstName}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="165" y="0" width="100" height="22"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{lastName}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="265" y="0" width="130" height="22" forecolor="#1565C0"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{login}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true" pattern="dd-MM-yyyy">
                <reportElement x="395" y="0" width="80" height="22" forecolor="#555555"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{dob}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="475" y="0" width="100" height="22"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{mobileNo}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="575" y="0" width="65" height="22"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{gender}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="640" y="0" width="60" height="22" forecolor="#888888"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{roleId}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="700" y="0" width="82" height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{lock}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <pageFooter>
        <band height="20">
            <line>
                <reportElement x="0" y="0" width="782" height="1" forecolor="#CCCCCC"/>
            </line>
            <staticText>
                <reportElement x="0" y="3" width="391" height="16" forecolor="#888888"/>
                <textElement><font size="8"/></textElement>
                <text><![CDATA[Online Result System - User List Report]]></text>
            </staticText>
            <textField>
                <reportElement x="391" y="3" width="391" height="16" forecolor="#888888"/>
                <textElement textAlignment="Right"><font size="8"/></textElement>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <summary>
        <band height="30">
            <line>
                <reportElement x="0" y="4" width="782" height="1" forecolor="#CCCCCC"/>
            </line>
            <textField>
                <reportElement x="0" y="10" width="400" height="18" forecolor="#1565C0"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["Total Users: " + $V{REPORT_COUNT}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
